# ── Nosana GPU Endpoint ──────────────────────────────────────
# Points to the Qwen3.5-27B-AWQ-4bit model served on Nosana
NOSANA_ENDPOINT=http://localhost:8080/v1
NOSANA_API_KEY=nosana
NOSANA_MODEL=Qwen/Qwen3-32B-AWQ

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./data/sentinel.db
